   ],
   "source": [
    "#| echo: true\n",
    "#| output: true\n",
    "\n",
    "k_superior = 11\n",
    "k_inferior = 7\n",
    "\n",
    "prob = binom.cdf(k_superior, n, p) - binom.cdf(k_inferior - 1, n, p)\n",
    "print(f\"P({k_inferior} <= X <= {k_superior}): {prob:.4f}\")"
